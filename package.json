{
  "name": "my-dev-portfolio",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "next": "^16.1.1",
      "@prisma/client": "^7.5.0",
      "@ts-rest/core": "^3.52.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @my-dev-portfolio/db db:push",
    "db:studio": "turbo -F @my-dev-portfolio/db db:studio",
    "db:generate": "turbo -F @my-dev-portfolio/db db:generate",
    "db:migrate": "turbo -F @my-dev-portfolio/db db:migrate"
  },
  "dependencies": {
    "@my-dev-portfolio/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-dev-portfolio/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
